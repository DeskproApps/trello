{
  "name": "deskpro-app-trello",
  "version": "0.2.3",
  "description": "Trello integration built with deskpro apps sdk",
  "main": "lib/main/javascript/index.js",
  "scripts": {
    "dev": "dpat server .",
    "package": "dpat clean . && dpat compile . && dpat package .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeskproApps/app-trello.git"
  },
  "keywords": [
    "deskpro",
    "apps",
    "deskpro",
    "sdk"
  ],
  "author": {
    "name": "Deskproapps",
    "email": "apps@deskpro.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DeskproApps/app-trello/issues"
  },
  "homepage": "https://github.com/DeskproApps/app-trello#readme",
  "dependencies": {
    "@deskproapps/deskproapps-sdk-react": "1.0.0-alpha.11"
  },
  "devDependencies": {
    "error-wrapper": "2.1.0",
    "react": "15.5.3",
    "react-custom-scrollbars": "4.1.1",
    "react-dom": "15.5.3",
    "semantic-ui-react": "0.67.2",
    "superagent": "3.5.2",
    "superagent-promise": "1.1.0"
  },
  "deskpro" : {
    "version": "2.1.0",
    "title": "Trello",
    "isSingle": true,
    "scope": "agent",
    "targets": [
      { "target": "ticket-sidebar", "url": "html/index.html" }
    ],
    "settings": [],
    "deskproApiTags": ["tickets.*"],
    "externalApis": []
  }
}
